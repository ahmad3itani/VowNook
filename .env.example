APP_NAME=VowNook
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: APP_URL=https://vownook.com (drives canonical URLs, sitemap, OG, emails)
APP_URL=http://localhost

# Bare domain for couples' free wedding-site subdomains (name.vownook.com).
# Needs a wildcard *.vownook.com DNS record + the wildcard domain attached in hosting.
APP_ROOT_DOMAIN=vownook.com

# ── Analytics & Search Console (all optional; tracking loads in production only,
#    after the visitor consents). Verification tags render whenever set. ──────────
GA_MEASUREMENT_ID=
MS_CLARITY_ID=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
# ANALYTICS_FORCE=true   # load tracking outside production (staging tests)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@vownook.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── AI assistance (Anthropic Claude) ──────────────────────────────────────────
# Powers the couple/planner "AI Plan Starter" (checklist, budget, timeline).
# The feature degrades gracefully: with no key set, AI endpoints report
# "not configured" and the rest of the app is unaffected. NEVER commit a key.
#
# ANTHROPIC_API_KEY=          # required to enable AI; get one at console.anthropic.com
# AI_ENABLED=true             # master switch (default true; needs a key to actually run)
# AI_MODEL=claude-sonnet-4-6  # generation model (balanced cost/quality)
# AI_MAX_TOKENS=8000          # per-response ceiling
# AI_TIMEOUT=60               # upstream request timeout (seconds)

# ── Marketplace payments (Stripe Connect) ─────────────────────────────────────
# Couples pay deposit/balance via hosted Stripe Checkout; the platform takes its
# commission (config/marketplace.php) and the rest is paid out to the vendor's
# connected Express account. With no keys set, payments degrade gracefully
# (buttons hidden, webhook no-ops). Use TEST keys in staging:
#   stripe listen --forward-to <APP_URL>/stripe/webhook   (prints the signing secret)
#
# STRIPE_KEY=pk_test_...
# STRIPE_SECRET=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Production ────────────────────────────────────────────────────────────────
# Recommended overrides when deploying. Uncomment and fill in as needed.
#
# PRODUCTION CHECKLIST
# - APP_DEBUG=false             (never expose debug pages in production)
# - SESSION_ENCRYPT=true        (encrypt session payloads at rest)
# - QUEUE_CONNECTION=database   (requires a `php artisan queue:work` daemon)
# - MAIL_MAILER=smtp            (real outgoing mail instead of the log driver)
#
# Never run production with debug enabled:
# APP_DEBUG=false
#
# Encrypt session payloads at rest:
# SESSION_ENCRYPT=true
#
# Real outgoing mail — required in production, set MAIL_MAILER=smtp
# (offer/inquiry notifications):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=your-smtp-username
# MAIL_PASSWORD=your-smtp-password
# MAIL_ENCRYPTION=tls
#
# PostgreSQL instead of the default SQLite:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=wedding
# DB_USERNAME=wedding
# DB_PASSWORD=
#
# S3 for uploads (vendor media, website photos):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ca-central-1
# AWS_BUCKET=

# Tiered platform commission on marketplace bookings:
# RATE on the portion up to THRESHOLD_CENTS, RATE_ABOVE on the remainder,
# total fee capped at CAP_CENTS. Defaults: 8% / 5% over $5,000 / $1,000 cap.
MARKETPLACE_COMMISSION_RATE=0.08
MARKETPLACE_COMMISSION_RATE_ABOVE=0.05
MARKETPLACE_COMMISSION_THRESHOLD_CENTS=500000
MARKETPLACE_COMMISSION_CAP_CENTS=100000

# QUEUE_CONNECTION=database requires a queue worker daemon in production
# (e.g. `php artisan queue:work` under Supervisor/systemd) so queued mail
# and notifications are actually delivered.

# ── Lifecycle & marketing email (scheduler) ───────────────────────────────────
# Welcome emails, countdown milestones, weekly digests, RSVP reminders, vendor
# re-engagement, plan-comp expiry and the post-wedding flow run on the Laravel
# scheduler. Production REQUIRES a single cron entry:
#   * * * * * cd /path/to/app && php artisan schedule:run >> /dev/null 2>&1
# (and a running queue worker, above, so the queued mail actually sends).
#
# CASL: marketing email must identify the sender with a physical mailing address.
# MAIL_CASL_ADDRESS="VowNook, 123 Example St, Toronto, ON, Canada"

# ── Server-Side Rendering (SSR) for SEO ───────────────────────────────────────
# The SEO <head> (title, meta, canonical, JSON-LD) is server-rendered by blade
# regardless of SSR. SSR additionally server-renders the page BODY so crawlers
# (and AI assistants) see full content. It requires a managed Node SSR process.
#
# Local `php artisan serve` is single-threaded and cannot reliably reach the SSR
# process mid-request, so keep SSR OFF locally. Enable it on staging/production:
#
#   1. Build the SSR bundle:    pnpm build:ssr   (emits bootstrap/ssr/app.js)
#   2. Run the SSR process:     php artisan inertia:start-ssr   (under Supervisor)
#   3. Set the vars below.
#
# INERTIA_SSR_ENABLED=true
# INERTIA_SSR_URL=http://127.0.0.1:13714
# INERTIA_SSR_THROW=false        # set true temporarily to debug SSR render errors
