# ──────────────────────────────────────────────────────────────────────────────
# VowNook — PRODUCTION environment template.
# Copy this into Forge's "Environment" editor for the site, fill every value,
# and deploy. NEVER commit real secrets. Generate APP_KEY with `php artisan key:generate`.
# ──────────────────────────────────────────────────────────────────────────────

APP_NAME=VowNook
APP_ENV=production
APP_KEY=                       # php artisan key:generate --show  (then paste here)
APP_DEBUG=false                # MUST be false in production
APP_URL=https://vownook.com    # the canonical https domain (drives SEO/canonicals/emails)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Force HTTPS + correct client IPs behind the load balancer.
# (TrustProxies is already configured to trust the proxy.)

# ── Database — managed Postgres (Forge provisions this) ───────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=vownook
DB_USERNAME=forge
DB_PASSWORD=                   # from Forge's database panel

# ── Sessions / cache / queue ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database      # REQUIRES a `queue:work` daemon (Forge → Daemons)

# ── Object storage for uploads (R2 or S3, ca-central-1) ───────────────────────
# Vendor media, wedding-website photos, blog images, brochures live here.
# Local disk is ephemeral on a deploy — DO NOT use local in prod.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ca-central-1
AWS_BUCKET=vownook
AWS_USE_PATH_STYLE_ENDPOINT=false
# For Cloudflare R2 instead of S3, also set:
# AWS_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# AWS_URL=https://cdn.vownook.com

# ── Mail (Resend recommended) ─────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=                 # Resend API key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@vownook.com"
MAIL_FROM_NAME="VowNook"
# CASL: a real physical mailing address shown in marketing-email footers.
MAIL_CASL_ADDRESS="VowNook, <street>, Toronto, ON, Canada"

# ── AI assistant (optional; paid couples + planners) ──────────────────────────
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-6

# ── Stripe Connect (only when you're ready to take money) ─────────────────────
# Use TEST keys on staging first; swap to live keys after the test-card pass.
# STRIPE_KEY=
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=        # from the webhook endpoint you register in Stripe

# ── SEO server-side rendering (optional, recommended) ─────────────────────────
# INERTIA_SSR_ENABLED=true      # then run `php artisan inertia:start-ssr` as a daemon

LOG_CHANNEL=stack
LOG_LEVEL=warning
